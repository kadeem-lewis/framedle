    "party-js": "^2.2.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "postgres": "^3.4.8",
    "redis": "^5.10.0",
    "rxjs": "^7.8.2",
    "tailwindcss": "^4.2.1",
    "vue3-apexcharts": "^1.10.0",
    "zod": "^4.3.6"
