{
  "name": "framedle",
  "private": true,
  "type": "module",
  "version": "1.2.3",
  "scripts": {
    "build": "NODE_OPTIONS=--max_old_space_size=8192 nuxt build",
    "dev": "doppler run -- nuxt dev",
    "generate": "nuxt generate",
    "start": "node --import ./.output/server/sentry.server.config.mjs .output/server/index.mjs",
    "preview": "doppler run -- nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "nuxt typecheck",
    "db:generate": "drizzle-kit generate",
    "db:push": "doppler run -- drizzle-kit push",
    "test": "vitest",
    "generate-pwa-assets": "pwa-assets-generator --preset minimal-2023 public/logo.svg"
  },
  "devDependencies": {
    "@iconify-json/heroicons": "^1.2.3",
    "@iconify-json/mdi": "^1.2.3",
    "@nuxt/devtools": "^3.2.1",
    "@nuxt/eslint": "^1.15.1",
    "@nuxt/image": "^2.0.0",
    "@nuxt/scripts": "^0.13.2",
    "@nuxt/test-utils": "^4.0.0",
    "@nuxt/ui": "4.4.0",
    "@nuxtjs/i18n": "^10.2.3",
    "@nuxtjs/seo": "3.4.0",
    "@types/luaparse": "^0.2.13",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vue/test-utils": "^2.4.6",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.2",
    "happy-dom": "^20.6.1",
    "nuxt": "^4.3.1",
    "nuxt-security": "^2.5.1",
    "playwright-core": "^1.58.2",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.2",
    "vue-tsc": "^3.2.4"
  },
  "packageManager": "pnpm@9.12.2",
  "dependencies": {
    "@pinia/nuxt": "^0.11.3",
    "@sentry/nuxt": "^10.38.0",
    "@typescript-eslint/parser": "^8.55.0",
