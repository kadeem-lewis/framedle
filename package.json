    "dexie": "^4.4.3",
    "drizzle-orm": "^0.45.2",
    "fuse.js": "^7.4.0",
    "import-in-the-middle": "^3.0.1",
    "luaparse": "^0.3.1",
    "motion-v": "^2.2.1",
    "party-js": "^2.2.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "postgres": "^3.4.9",
    "redis": "^6.0.0",
    "rxjs": "^7.8.2",
    "tailwindcss": "^4.3.0",
    "vue3-apexcharts": "^1.11.1",
