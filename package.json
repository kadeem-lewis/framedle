    "@nuxt/devtools": "4.0.0-alpha.6",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/image": "^2.0.0",
    "@nuxt/scripts": "^1.1.1",
    "@nuxt/test-utils": "^4.0.3",
    "@nuxt/ui": "4.8.2",
    "@nuxtjs/mdc": "0.22.0",
    "@nuxtjs/seo": "^5.1.3",
    "@nuxtjs/turnstile": "1.1.3",
    "@types/luaparse": "^0.2.13",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vue/test-utils": "^2.4.10",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.4.1",
    "happy-dom": "^20.9.0",
    "nuxt": "^4.4.6",
    "nuxt-security": "^2.6.0",
    "playwright-core": "^1.60.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7",
    "vue-tsc": "^3.3.3"
  },
  "packageManager": "pnpm@11.5.0",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1069.0",
    "@notionhq/client": "^5.22.0",
    "@pinia/nuxt": "^0.11.3",
    "@sentry/nuxt": "^10.55.0",
    "@takumi-rs/core": "^1.6.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vite-pwa/nuxt": "^1.1.1",
    "@vueuse/core": "^14.3.0",
    "@vueuse/nuxt": "^14.3.0",
    "@vueuse/rxjs": "^14.3.0",
    "apexcharts": "^5.13.0",
